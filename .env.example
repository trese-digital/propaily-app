# Postgres + PostGIS (DB compartida con cartografía).
# Schema "propaily" lo maneja Prisma; el schema "public" (catastro) lo maneja Alembic
# desde el backend FastAPI de cartografia-gfc.
# Usar 127.0.0.1 SIEMPRE — "localhost" cuelga el handshake en Windows.
DATABASE_URL="postgresql://gfc:gfc_dev_2026@127.0.0.1:5432/cartografia_gfc_dev?schema=propaily"
# DIRECT_URL es lo mismo que DATABASE_URL en local; en prod (con pgbouncer) apunta al endpoint directo.
DIRECT_URL="postgresql://gfc:gfc_dev_2026@127.0.0.1:5432/cartografia_gfc_dev?schema=propaily"

# Supabase Auth + Storage.
# La service_role NUNCA debe filtrarse al cliente. Sólo se usa en src/server/.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
